# Copy this file to `.env` and fill in real values. `.env` is gitignored; this template is committed.
# The harness loads `.env` automatically (see load_dotenv() in reliability_probe_v2.py).
# Precedence: a variable already set in your shell environment WINS over .env (so secret
# managers / CI are never overridden). If it's not set in the shell, .env supplies it.

# Required for the Anthropic provider (probe model = claude-haiku-4-5-20251001).
ANTHROPIC_API_KEY=

# Optional — only needed if you run the OpenAI provider for the panel later.
OPENAI_API_KEY=
